{
  "name": "@yad/extension",
  "displayName": "YouTube Ad Detector",
  "version": "0.0.1",
  "description": "유튜브 허위·과장 광고 의심신호 탐지 확장",
  "author": "yad",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@yad/shared": "*",
    "plasmo": "^0.89.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.5.4"
  },
  "manifest": {
    "name": "YouTube Ad Detector",
    "host_permissions": ["https://www.youtube.com/*"],
    "permissions": ["tabs", "storage"]
  }
}
